from __future__ import annotations

import json
from collections import Counter
from pathlib import Path
from typing import Any, Iterable, Mapping

from signalforge.engines.alignment.regime_asset_options_alignment import (
    build_signalforge_regime_asset_options_alignment,
)
from signalforge.engines.strategy_selection.strategy_family_eligibility import (
    build_signalforge_strategy_family_eligibility,
)


def read_jsonl(path: str | Path) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    with Path(path).open("r", encoding="utf-8") as handle:
        for line_number, line in enumerate(handle, start=1):
            stripped = line.strip()
            if not stripped:
                continue
            try:
                payload = json.loads(stripped)
            except json.JSONDecodeError as exc:
                raise ValueError(f"Invalid JSONL at line {line_number}: {exc}") from exc
            if not isinstance(payload, dict):
                raise ValueError(f"Expected JSON object at line {line_number}.")
            rows.append(payload)
    return rows


def write_jsonl(path: str | Path, rows: Iterable[Mapping[str, Any]]) -> None:
    output_path = Path(path)
    output_path.parent.mkdir(parents=True, exist_ok=True)

    with output_path.open("w", encoding="utf-8", newline="\n") as handle:
        for row in rows:
            handle.write(json.dumps(row, sort_keys=True, separators=(",", ":"), default=str))
            handle.write("\n")


def write_json(path: str | Path, payload: Mapping[str, Any]) -> None:
    output_path = Path(path)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(
        json.dumps(payload, indent=2, sort_keys=True, default=str) + "\n",
        encoding="utf-8",
    )


def _as_mapping(value: Any) -> dict[str, Any]:
    return dict(value) if isinstance(value, Mapping) else {}


def _clean_text(value: Any) -> str:
    return str(value).strip() if value is not None else ""


def _symbol(row: Mapping[str, Any]) -> str:
    return _clean_text(row.get("symbol")).upper()


def _source_date(item: Mapping[str, Any], row: Mapping[str, Any]) -> str | None:
    for key in ("source_date", "decision_date", "as_of_date", "date"):
        value = item.get(key) or row.get(key)
        if value:
            return _clean_text(value)
    return None


def _with_common_aliases(
    item: Mapping[str, Any],
    *,
    row: Mapping[str, Any],
    symbol: str,
    state_aliases: tuple[str, ...],
) -> dict[str, Any]:
    out = dict(item)
    out.setdefault("symbol", symbol)

    state = out.get("state")
    if state is not None:
        for alias in state_aliases:
            out.setdefault(alias, state)

    source_date = _source_date(out, row)
    if source_date:
        out.setdefault("source_date", source_date)
        out.setdefault("as_of_date", source_date)
        out.setdefault("date", source_date)

    return out


def _single_row_sources(row: Mapping[str, Any]) -> tuple[dict[str, Any], dict[str, Any], dict[str, Any]]:
    symbol = _symbol(row)

    regime = _with_common_aliases(
        _as_mapping(row.get("regime")),
        row=row,
        symbol=symbol,
        state_aliases=("regime_state", "macro_regime", "market_regime"),
    )

    asset_behavior = _with_common_aliases(
        _as_mapping(row.get("asset_behavior")),
        row=row,
        symbol=symbol,
        state_aliases=("asset_behavior_state", "behavior_state"),
    )

    option_behavior = _with_common_aliases(
        _as_mapping(row.get("option_behavior")),
        row=row,
        symbol=symbol,
        state_aliases=("option_behavior_state", "options_behavior_state", "behavior_state"),
    )

    regime_source = {
        "artifact_type": "historical_decision_row_regime_source",
        "is_ready": True,
        "symbol": symbol,
        "regime": regime,
        "market_regime": regime,
        "macro_regime": regime.get("macro_regime") or regime.get("regime_state") or regime.get("state"),
        "regime_state": regime.get("regime_state") or regime.get("state"),
        "source_date": regime.get("source_date"),
        "as_of_date": regime.get("as_of_date"),
        "regime_rows": [regime],
        "weekly_regime_rows": [regime],
        "historical_regime_rows": [regime],
        "items": [regime],
    }

    asset_behavior_source = {
        "artifact_type": "historical_decision_row_asset_behavior_source",
        "is_ready": True,
        "symbol": symbol,
        "asset_behavior": asset_behavior,
        "asset_behavior_state": asset_behavior.get("asset_behavior_state") or asset_behavior.get("state"),
        "asset_behavior_rows": [asset_behavior],
        "asset_behavior_items": [asset_behavior],
        "historical_asset_behavior_rows": [asset_behavior],
        "decision_rows": [asset_behavior],
        "items": [asset_behavior],
    }

    options_behavior_source = {
        "artifact_type": "historical_decision_row_options_behavior_source",
        "is_ready": True,
        "symbol": symbol,
        "option_behavior": option_behavior,
        "options_behavior": option_behavior,
        "option_behavior_state": option_behavior.get("option_behavior_state") or option_behavior.get("state"),
        "options_behavior_state": option_behavior.get("options_behavior_state") or option_behavior.get("state"),
        "option_behavior_rows": [option_behavior],
        "options_behavior_rows": [option_behavior],
        "option_behavior_items": [option_behavior],
        "options_behavior_items": [option_behavior],
        "historical_option_behavior_rows": [option_behavior],
        "decision_rows": [option_behavior],
        "items": [option_behavior],
    }

    return regime_source, asset_behavior_source, options_behavior_source


def _first_mapping(payload: Mapping[str, Any], keys: tuple[str, ...]) -> dict[str, Any]:
    for key in keys:
        value = payload.get(key)
        if isinstance(value, list):
            for item in value:
                if isinstance(item, Mapping):
                    return dict(item)
        elif isinstance(value, Mapping):
            return dict(value)
    return {}


def _as_string_list(value: Any) -> list[str]:
    if isinstance(value, str):
        return [value] if value else []
    if isinstance(value, list):
        return [_clean_text(item) for item in value if _clean_text(item)]
    if isinstance(value, tuple):
        return [_clean_text(item) for item in value if _clean_text(item)]
    if isinstance(value, set):
        return sorted(_clean_text(item) for item in value if _clean_text(item))
    return []


def _family_statuses_from_item(item: Mapping[str, Any]) -> dict[str, str]:
    value = item.get("strategy_family_statuses")
    if isinstance(value, Mapping):
        return {str(k): str(v) for k, v in value.items()}

    statuses: dict[str, str] = {}

    for family in _as_string_list(item.get("favored_strategy_families")):
        statuses[family] = "favored"

    for family in _as_string_list(item.get("allowed_strategy_families")):
        statuses.setdefault(family, "allowed")

    for family in _as_string_list(item.get("discouraged_strategy_families")):
        statuses[family] = "discouraged"

    for family in _as_string_list(item.get("blocked_strategy_families")):
        statuses[family] = "blocked"

    return statuses


def enrich_decision_row_with_strategy_family_eligibility(
    row: Mapping[str, Any],
    *,
    include_engine_artifacts: bool = False,
) -> dict[str, Any]:
    enriched = dict(row)

    try:
        regime_source, asset_behavior_source, options_behavior_source = _single_row_sources(row)

        alignment_artifact = build_signalforge_regime_asset_options_alignment(
            regime_source=regime_source,
            asset_behavior_source=asset_behavior_source,
            options_behavior_source=options_behavior_source,
        )

        alignment_item = _first_mapping(
            alignment_artifact,
            (
                "regime_asset_options_alignment_items",
                "alignment_items",
                "items",
            ),
        )

        eligibility_artifact = build_signalforge_strategy_family_eligibility(alignment_artifact)

        eligibility_item = _first_mapping(
            eligibility_artifact,
            (
                "strategy_family_eligibility_items",
                "eligibility_items",
                "items",
            ),
        )

        family_statuses = _family_statuses_from_item(eligibility_item)

        enriched["regime_asset_options_alignment"] = alignment_item
        enriched["strategy_family_eligibility"] = eligibility_item
        enriched["favored_strategy_families"] = _as_string_list(
            eligibility_item.get("favored_strategy_families")
        )
        enriched["allowed_strategy_families"] = _as_string_list(
            eligibility_item.get("allowed_strategy_families")
        )
        enriched["discouraged_strategy_families"] = _as_string_list(
            eligibility_item.get("discouraged_strategy_families")
        )
        enriched["blocked_strategy_families"] = _as_string_list(
            eligibility_item.get("blocked_strategy_families")
        )
        enriched["review_required_strategy_families"] = _as_string_list(
            eligibility_item.get("review_required_strategy_families")
        )
        enriched["strategy_family_statuses"] = family_statuses
        enriched["strategy_family_matrix_metadata_items"] = list(
            eligibility_item.get("strategy_family_matrix_metadata_items") or []
        )
        enriched["matrix_metadata_strategy_family_summary"] = eligibility_item.get(
            "matrix_metadata_strategy_family_summary"
        )
        enriched["strategy_family_eligibility_handoff"] = eligibility_item.get(
            "strategy_family_eligibility_handoff"
        )

        enriched["strategy_family_eligibility_enrichment"] = {
            "artifact_type": "historical_strategy_family_eligibility_enrichment_item",
            "enrichment_state": "available",
            "symbol": _symbol(row),
            "alignment_item_available": bool(alignment_item),
            "eligibility_item_available": bool(eligibility_item),
            "strategy_family_status_count": len(family_statuses),
        }

        if include_engine_artifacts:
            enriched["regime_asset_options_alignment_artifact"] = alignment_artifact
            enriched["strategy_family_eligibility_artifact"] = eligibility_artifact

        return enriched

    except Exception as exc:
        enriched["strategy_family_eligibility_enrichment"] = {
            "artifact_type": "historical_strategy_family_eligibility_enrichment_item",
            "enrichment_state": "error",
            "symbol": _symbol(row),
            "error_type": type(exc).__name__,
            "error_message": str(exc),
        }
        enriched.setdefault("strategy_family_statuses", {})
        return enriched


def build_historical_strategy_family_eligibility_enrichment(
    decision_rows: Iterable[Mapping[str, Any]],
    *,
    include_engine_artifacts: bool = False,
) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    rows = [
        enrich_decision_row_with_strategy_family_eligibility(
            row,
            include_engine_artifacts=include_engine_artifacts,
        )
        for row in decision_rows
    ]

    enrichment_counts = Counter(
        _clean_text(
            ((row.get("strategy_family_eligibility_enrichment") or {}).get("enrichment_state"))
        )
        or "missing"
        for row in rows
    )

    family_status_counts: Counter[str] = Counter()
    rows_with_family_statuses = 0

    for row in rows:
        statuses = row.get("strategy_family_statuses")
        if isinstance(statuses, Mapping) and statuses:
            rows_with_family_statuses += 1
            for status in statuses.values():
                family_status_counts[str(status)] += 1

    blockers: list[str] = []

    if not rows:
        blockers.append("no_decision_rows")

    if enrichment_counts.get("error", 0):
        blockers.append("strategy_family_eligibility_enrichment_errors")

    if rows and rows_with_family_statuses == 0:
        blockers.append("no_rows_with_strategy_family_statuses")

    summary = {
        "adapter_type": "historical_strategy_family_eligibility_enrichment_builder",
        "artifact_type": "signalforge_historical_strategy_family_eligibility_enrichment",
        "contract": "historical_strategy_family_eligibility_enrichment",
        "is_ready": len(blockers) == 0,
        "blocker_count": len(blockers),
        "blockers": blockers,
        "input_decision_row_count": len(rows),
        "output_decision_row_count": len(rows),
        "rows_with_strategy_family_statuses": rows_with_family_statuses,
        "strategy_family_status_coverage": (
            rows_with_family_statuses / len(rows) if rows else 0.0
        ),
        "enrichment_state_counts": dict(sorted(enrichment_counts.items())),
        "strategy_family_status_counts": dict(sorted(family_status_counts.items())),
        "paths": {},
    }

    return rows, summary


def build_historical_strategy_family_eligibility_enrichment_artifact(
    *,
    decision_rows_path: str | Path,
    output_dir: str | Path,
    include_engine_artifacts: bool = False,
) -> dict[str, Any]:
    output_path = Path(output_dir)
    rows_path = output_path / "signalforge_historical_strategy_family_eligibility_enriched_decision_rows.jsonl"
    summary_path = output_path / "signalforge_historical_strategy_family_eligibility_enrichment_summary.json"

    decision_rows = read_jsonl(decision_rows_path)

    rows, summary = build_historical_strategy_family_eligibility_enrichment(
        decision_rows,
        include_engine_artifacts=include_engine_artifacts,
    )

    summary["paths"] = {
        "decision_rows_path": str(decision_rows_path),
        "rows_path": str(rows_path),
        "summary_path": str(summary_path),
    }

    write_jsonl(rows_path, rows)
    write_json(summary_path, summary)

    return summary
