# ============================================================
# SignalForge Git Ignore
# Keep source, tests, config, docs, and small deterministic samples.
# Ignore local envs, runtime outputs, imported/vendor data, caches, and secrets.
# ============================================================

# ----------------------------
# Python caches / build output
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.cache/
.tox/
.nox/
build/
dist/
*.egg-info/
.eggs/

# ----------------------------
# Virtual environments
# ----------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/

# ----------------------------
# Local secrets / env files
# ----------------------------
.env
.env.*
!.env.example
.envrc
.pypirc

# ----------------------------
# Runtime artifacts / generated outputs
# ----------------------------
artifacts/
exports/
reports/
logs/
imports/
downloads/
*.jsonl

artifacts/
exports/
reports/
logs/
imports/
downloads/

# ----------------------------
# Local/imported data
# Keep data/samples versioned.
# ----------------------------
data/raw/
data/imports/
data/downloads/
data/manual/
data/vendor/
data/tmp/
data/local/
data/runtime/
data/canonical/
data/qc_transfer/

# ----------------------------
# Notebooks / editor state
# ----------------------------
.ipynb_checkpoints/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
tempCodeRunnerFile.py

# ----------------------------
# OS files
# ----------------------------
.DS_Store
Thumbs.db

# ----------------------------
# Logs / databases
# ----------------------------
*.log
*.sqlite
*.sqlite3
db.sqlite3
db.sqlite3-journal

# ----------------------------
# Parquet and binary data outputs
# ----------------------------
*.parquet
*.feather
*.arrow

# But allow explicit tiny fixtures later if we intentionally create them.
!data/samples/**/*.json
!data/samples/**/*.csv
!data/samples/**/*.yaml
!data/samples/**/*.yml
!data/fixtures/**/*.parquet

# Local parking for cleanup/recovery files.
local_parking/
